{
  "ConnectionStrings": {
    "MetadataDb": "Data Source=metadata.db",
    "ChunkStorageDb": "Data Source=chunkstorage.db"
  },
  "RabbitMq": {
    "HostName": "localhost",
    "Exchange": "logs_exchange",
    "UserName": "guest",
    "Password": "guest"
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information"
    },
    "WriteTo": [
      {
        "Name": "File",
        "Args": {
          "path": "logs/log-.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7,
          "shared": true
        }
      }
    ]
  }
}
